{
  "name": "@gvf/core",
  "version": "0.1.0",
  "description": "GVF core — workspace, sampling, analysis, selection, pipeline handlers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GetVideoFrames/gvf.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/GetVideoFrames/gvf#readme",
  "bugs": {
    "url": "https://github.com/GetVideoFrames/gvf/issues"
  },
  "type": "module",
